<mujoco model="marsdog scene">
  <include file="marsdog.xml" />

  <statistic center="0.4 0 0.3" extent="1.2" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
    <rgba haze="0.15 0.25 0.35 1" />
    <global azimuth="-140" elevation="-20" />
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <!-- floor -->
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="step" rgba="0.55 0.55 0.58 1" />
  </asset>

  <worldbody>
    <!-- 机器人前方 box 台阶-->
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" pos="0 0 -0.3" size="0 0 0.05" type="plane" material="groundplane" />
    <!-- <geom name="step1" type="box" size="0.8 0.40 0.3" pos="0 -1.9 0.02" material="step" friction="0.8 0.005 0.0001" /> -->
  </worldbody>
</mujoco>
